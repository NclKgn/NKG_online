---
// src/pages/phd/dashboard.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import CollecteDashboard from '../../components/CollecteDashboard.astro';
import ThesisTracker from '../../components/ThesisTracker.astro';
import PhDTimeline from '../../components/PhDTimeline.astro';
import PresentationToggle from '../../components/PresentationToggle.astro';
import FigureTracker from '../../components/FigureTracker.astro';
import SpecimenTracker from '../../components/SpecimenTracker.astro';
import ExperimentsLiveTracker from '../../components/ExperimentsLiveTracker.astro';
import DefenseChecklist from '../../components/DefenseChecklist.astro';
import PipelineTracker from '../../components/PipelineTracker.astro';
import DataSharingStatus from '../../components/DataSharingStatus.astro';
import PubMedRadar from '../../components/PubMedRadar.astro';
import { base } from '../../i18n';
import { shouldBuild, shouldNoIndex } from '../../lib/visibility';
import { t, getLocale } from '../../i18n';
const ui = t(getLocale()).dashboard;

const pageKey = 'phd/dashboard';

// Private → redirect (pages buildées en prod seulement si public ou guest)
if (!(await shouldBuild(pageKey))) {
  return Astro.redirect(base('/'));
}

const noindex = await shouldNoIndex(pageKey);
---

<BaseLayout title="PhD Dashboard" noindex={noindex}>
  <div class="container section">

    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href={base('/phd')}>PhD</a>
      <span aria-hidden="true">/</span>
      <span>Dashboard</span>
    </nav>

    <div class="dash-header">
      <div>
        <h1>Dashboard</h1>
        <p class="dashboard-subtitle">{ui.subtitle}</p>
      </div>
      <PresentationToggle />
    </div>

    <!-- Vue d'ensemble collecte (EPIC 2.1) -->
    <details class="dash-section" open>
      <summary class="dash-section-summary"><h2>{ui.collecte.title}</h2><span class="dash-chevron" aria-hidden="true"></span></summary>
      <div class="dash-section-body"><CollecteDashboard /></div>
    </details>

    <!-- Checklist soutenance (EPIC 22.3/22.4) -->
    <details class="dash-section" open>
      <summary class="dash-section-summary"><h2>{ui.defense.title}</h2><span class="dash-chevron" aria-hidden="true"></span></summary>
      <div class="dash-section-body"><DefenseChecklist /></div>
    </details>

    <!-- Tracker rédaction (EPIC 3) -->
    <details class="dash-section" open>
      <summary class="dash-section-summary"><h2>{ui.thesis.title}</h2><span class="dash-chevron" aria-hidden="true"></span></summary>
      <div class="dash-section-body"><ThesisTracker /></div>
    </details>

    <!-- Timeline (EPIC 5) -->
    <details class="dash-section" open>
      <summary class="dash-section-summary"><h2>{ui.timeline.title}</h2><span class="dash-chevron" aria-hidden="true"></span></summary>
      <div class="dash-section-body"><PhDTimeline /></div>
    </details>

    <!-- Tracker spécimens (EPIC 14) -->
    <details class="dash-section" open>
      <summary class="dash-section-summary"><h2>{ui.specimens.title}</h2><span class="dash-chevron" aria-hidden="true"></span></summary>
      <div class="dash-section-body"><SpecimenTracker /></div>
    </details>

    <!-- Tracker expériences live (EPIC 13) -->
    <details class="dash-section" open>
      <summary class="dash-section-summary"><h2>{ui.experimentsLive.title}</h2><span class="dash-chevron" aria-hidden="true"></span></summary>
      <div class="dash-section-body"><ExperimentsLiveTracker /></div>
    </details>

    <!-- Tracker pipelines d'analyse (EPIC 18) -->
    <details class="dash-section" open>
      <summary class="dash-section-summary"><h2>{ui.pipelines.title}</h2><span class="dash-chevron" aria-hidden="true"></span></summary>
      <div class="dash-section-body"><PipelineTracker /></div>
    </details>

    <!-- Partage des données FAIR (EPIC 21) -->
    <details class="dash-section" open>
      <summary class="dash-section-summary"><h2>{ui.datasets.title}</h2><span class="dash-chevron" aria-hidden="true"></span></summary>
      <div class="dash-section-body"><DataSharingStatus /></div>
    </details>

    <!-- Radar littérature PubMed (EPIC 20) -->
    <details class="dash-section" open>
      <summary class="dash-section-summary"><h2>{ui.pubmed.title}</h2><span class="dash-chevron" aria-hidden="true"></span></summary>
      <div class="dash-section-body"><PubMedRadar /></div>
    </details>

    <!-- Tracker figures (EPIC 19) -->
    <details class="dash-section" open>
      <summary class="dash-section-summary"><h2>{ui.figures.title}</h2><span class="dash-chevron" aria-hidden="true"></span></summary>
      <div class="dash-section-body"><FigureTracker /></div>
    </details>

    <!-- Modules (liens) -->
    <section class="dash-modules">
      <h2>{ui.modules.title}</h2>
      <div class="modules-grid">

        <a href={base('/phd/experiments')} class="module-card card">
          <span class="module-icon">⚗</span>
          <div class="module-info">
            <span class="module-title">{ui.modules.experiments.title}</span>
            <span class="module-desc">{ui.modules.experiments.desc}</span>
          </div>
          <span class="module-arrow">→</span>
        </a>

        <div class="module-card card module-disabled">
          <span class="module-icon">✍</span>
          <div class="module-info">
            <span class="module-title">{ui.modules.writing.title}</span>
            <span class="module-desc">{ui.modules.writing.desc}</span>
          </div>
          <span class="coming-soon-badge">{ui.modules.comingSoon}</span>
        </div>

        <div class="module-card card module-disabled">
          <span class="module-icon">🔍</span>
          <div class="module-info">
            <span class="module-title">{ui.modules.scopingReview.title}</span>
            <span class="module-desc">{ui.modules.scopingReview.desc}</span>
          </div>
          <span class="coming-soon-badge">{ui.modules.comingSoon}</span>
        </div>

        <div class="module-card card module-disabled">
          <span class="module-icon">📅</span>
          <div class="module-info">
            <span class="module-title">{ui.modules.timeline.title}</span>
            <span class="module-desc">{ui.modules.timeline.desc}</span>
          </div>
          <span class="coming-soon-badge">{ui.modules.comingSoon}</span>
        </div>

      </div>
    </section>

    <!-- Liens rapides -->
    <section class="dash-links">
      <a href={base('/phd/newsletter')} class="mono dash-secondary-link">Newsletter →</a>
      <a href={base('/phd/lab')} class="mono dash-secondary-link">Cahier de labo →</a>
      <a href={base('/phd/meetings')} class="mono dash-secondary-link">Notes de réunion →</a>
    </section>

  </div>
</BaseLayout>

<style>
  .breadcrumb {
    font-size: 0.8rem;
    color: var(--c-text-3);
    margin-bottom: var(--space-lg);
    display: flex;
    gap: var(--space-xs, 6px);
    align-items: center;
  }

  .breadcrumb a {
    color: var(--c-text-3);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--c-accent);
  }

  .dash-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  h1 {
    font-size: 2.2rem;
    margin-bottom: var(--space-xs, 6px);
  }

  .dashboard-subtitle {
    font-size: 0.9rem;
    color: var(--c-text-2);
    font-style: italic;
    margin-bottom: 0;
  }

  /* ── Sections repliables ── */

  .dash-section {
    margin-bottom: var(--space-2xl);
  }

  .dash-section:not([open]) {
    margin-bottom: var(--space-xs, 4px);
  }

  .dash-section-summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    cursor: pointer;
    padding: var(--space-xs, 4px) 0;
    margin-bottom: var(--space-lg);
    user-select: none;
  }

  .dash-section-summary::-webkit-details-marker { display: none; }

  .dash-section:not([open]) .dash-section-summary {
    margin-bottom: 0;
  }

  .dash-section-summary h2 {
    margin-bottom: 0;
  }

  .dash-section-summary:hover h2 {
    color: var(--c-accent);
  }

  .dash-chevron {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    position: relative;
  }

  .dash-chevron::before,
  .dash-chevron::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 7px;
    height: 2px;
    background: var(--c-text-3);
    border-radius: 2px;
    transition: transform 0.2s ease;
  }

  .dash-chevron::before { left: 1px;  transform: translateY(-50%) rotate(-45deg); }
  .dash-chevron::after  { right: 1px; transform: translateY(-50%) rotate(45deg);  }

  .dash-section:not([open]) .dash-chevron::before { transform: translateY(-50%) rotate(45deg);  }
  .dash-section:not([open]) .dash-chevron::after  { transform: translateY(-50%) rotate(-45deg); }

  .dash-section-body {
    /* pas de padding supplémentaire — chaque composant gère son propre espacement */
  }

  /* ── Modules ── */

  .dash-modules {
    margin-bottom: var(--space-2xl);
  }

  .dash-modules h2 {
    margin-bottom: var(--space-lg);
  }

  .modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-md);
  }

  .module-card {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    text-decoration: none;
    color: var(--c-text);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  a.module-card:hover {
    border-color: var(--c-accent);
    box-shadow: 0 0 0 1px var(--c-accent);
  }

  .module-disabled {
    opacity: 0.55;
    cursor: default;
  }

  .module-icon {
    font-size: 1.4rem;
    flex-shrink: 0;
  }

  .module-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .module-title {
    font-size: 0.9rem;
    font-weight: 600;
  }

  .module-desc {
    font-size: 0.78rem;
    color: var(--c-text-3);
  }

  .module-arrow {
    color: var(--c-accent);
    font-size: 1rem;
  }

  /* ── Badge "bientôt" ── */

  .coming-soon-badge {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--c-text-3);
    background: var(--c-border);
    padding: 2px 7px;
    border-radius: 99px;
  }

  /* ── Liens rapides ── */

  .dash-links {
    display: flex;
    gap: var(--space-xl);
    flex-wrap: wrap;
    padding-top: var(--space-lg);
    border-top: 1px solid var(--c-border);
  }

  .dash-secondary-link {
    font-size: 0.82rem;
    color: var(--c-text-2);
    text-decoration: none;
  }

  .dash-secondary-link:hover {
    color: var(--c-accent);
  }

  @media (max-width: 768px) {
    .overview-stats {
      flex-direction: column;
    }

    .modules-grid {
      grid-template-columns: 1fr;
    }

    .dash-links {
      flex-direction: column;
      gap: var(--space-md);
    }
  }
</style>
