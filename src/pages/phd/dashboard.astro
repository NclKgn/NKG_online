---
// src/pages/phd/dashboard.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { base } from '../../i18n';
import { shouldBuild, shouldNoIndex } from '../../lib/visibility';
import { getCollection } from 'astro:content';

const pageKey = 'phd/dashboard';

// Private → redirect (pages buildées en prod seulement si public ou guest)
if (!(await shouldBuild(pageKey))) {
  return Astro.redirect(base('/'));
}

const noindex = await shouldNoIndex(pageKey);

// Données collecte pour aperçu rapide
const collecte = await getCollection('collecte');
const total = collecte.length;
const termines = collecte.filter((e) => e.data.statut === 'termine').length;
const enCours = collecte.filter((e) => e.data.statut === 'en-cours').length;

const axes = [
  { key: 'biologie', label: 'Biologie', color: '#6080a0', href: base('/phd/dashboard#biologie') },
  { key: 'biomecanique', label: 'Biomécanique', color: '#e07b2a', href: base('/phd/dashboard#biomecanique') },
  { key: 'donnees-humaines', label: 'Données Humaines', color: '#c0392b', href: base('/phd/dashboard#donnees-humaines') },
] as const;

function axeProgress(key: string): number {
  const items = collecte.filter((e) => e.data.partie === key);
  if (!items.length) return 0;
  return Math.round(items.reduce((acc, e) => acc + e.data.value, 0) / items.length);
}
---

<BaseLayout title="PhD Dashboard" noindex={noindex}>
  <div class="container section">

    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href={base('/phd')}>PhD</a>
      <span aria-hidden="true">/</span>
      <span>Dashboard</span>
    </nav>

    <h1>Dashboard</h1>
    <p class="dashboard-subtitle">Suivi de la collecte de données · Thèse en sciences biomédicales</p>

    <!-- Vue d'ensemble collecte -->
    <section class="dash-overview">
      <h2>Collecte de données</h2>
      <div class="overview-stats">
        <div class="stat-card card">
          <span class="stat-value mono">{termines}<span class="stat-total">/{total}</span></span>
          <span class="stat-label">Terminés</span>
        </div>
        <div class="stat-card card">
          <span class="stat-value mono">{enCours}</span>
          <span class="stat-label">En cours</span>
        </div>
        <div class="stat-card card">
          <span class="stat-value mono">{total - termines - enCours}</span>
          <span class="stat-label">Non démarrés</span>
        </div>
      </div>

      <!-- Progression par axe -->
      <div class="axes-grid">
        {axes.map((axe) => {
          const pct = axeProgress(axe.key);
          return (
            <div class="axe-card card">
              <div class="axe-header">
                <span class="axe-dot" style={`background: ${axe.color}`}></span>
                <span class="axe-label">{axe.label}</span>
                <span class="axe-pct mono">{pct}%</span>
              </div>
              <div class="axe-bar-track">
                <div class="axe-bar-fill" style={`width: ${pct}%; background: ${axe.color}`}></div>
              </div>
            </div>
          );
        })}
      </div>

      <a href={base('/phd/dashboard')} class="dash-link mono">
        Détail collecte → <span class="coming-soon-badge">bientôt</span>
      </a>
    </section>

    <!-- Modules (liens) -->
    <section class="dash-modules">
      <h2>Modules</h2>
      <div class="modules-grid">

        <a href={base('/phd/experiments')} class="module-card card">
          <span class="module-icon">⚗</span>
          <div class="module-info">
            <span class="module-title">Expériences</span>
            <span class="module-desc">Fiches structurées · hypothèses · protocoles</span>
          </div>
          <span class="module-arrow">→</span>
        </a>

        <div class="module-card card module-disabled">
          <span class="module-icon">✍</span>
          <div class="module-info">
            <span class="module-title">Rédaction</span>
            <span class="module-desc">Chapitres · publications · avancement</span>
          </div>
          <span class="coming-soon-badge">bientôt</span>
        </div>

        <div class="module-card card module-disabled">
          <span class="module-icon">🔍</span>
          <div class="module-info">
            <span class="module-title">Scoping Review</span>
            <span class="module-desc">Rayyan · extraction · synthèse</span>
          </div>
          <span class="coming-soon-badge">bientôt</span>
        </div>

        <div class="module-card card module-disabled">
          <span class="module-icon">📅</span>
          <div class="module-info">
            <span class="module-title">Timeline</span>
            <span class="module-desc">Jalons · livrables · soutenance</span>
          </div>
          <span class="coming-soon-badge">bientôt</span>
        </div>

      </div>
    </section>

    <!-- Liens rapides -->
    <section class="dash-links">
      <a href={base('/phd/newsletter')} class="mono dash-secondary-link">Newsletter →</a>
      <a href={base('/phd/lab')} class="mono dash-secondary-link">Cahier de labo →</a>
      <a href={base('/phd/meetings')} class="mono dash-secondary-link">Notes de réunion →</a>
    </section>

  </div>
</BaseLayout>

<style>
  .breadcrumb {
    font-size: 0.8rem;
    color: var(--c-text-3);
    margin-bottom: var(--space-lg);
    display: flex;
    gap: var(--space-xs, 6px);
    align-items: center;
  }

  .breadcrumb a {
    color: var(--c-text-3);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--c-accent);
  }

  h1 {
    font-size: 2.2rem;
    margin-bottom: var(--space-xs, 6px);
  }

  .dashboard-subtitle {
    font-size: 0.9rem;
    color: var(--c-text-2);
    font-style: italic;
    margin-bottom: var(--space-xl);
  }

  /* ── Overview ── */

  .dash-overview {
    margin-bottom: var(--space-2xl);
  }

  .dash-overview h2 {
    margin-bottom: var(--space-lg);
  }

  .overview-stats {
    display: flex;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
    flex-wrap: wrap;
  }

  .stat-card {
    flex: 1;
    min-width: 100px;
    padding: var(--space-md) var(--space-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs, 4px);
  }

  .stat-value {
    font-size: 2rem;
    font-weight: 700;
    color: var(--c-text);
    line-height: 1;
  }

  .stat-total {
    font-size: 1rem;
    color: var(--c-text-3);
  }

  .stat-label {
    font-size: 0.78rem;
    color: var(--c-text-3);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* ── Axes ── */

  .axes-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .axe-card {
    padding: var(--space-md) var(--space-lg);
  }

  .axe-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .axe-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .axe-label {
    flex: 1;
    font-size: 0.88rem;
    font-weight: 600;
  }

  .axe-pct {
    font-size: 0.82rem;
    color: var(--c-text-2);
  }

  .axe-bar-track {
    height: 5px;
    background: var(--c-border);
    border-radius: 99px;
    overflow: hidden;
  }

  .axe-bar-fill {
    height: 100%;
    border-radius: 99px;
    transition: width 0.4s ease;
  }

  .dash-link {
    font-size: 0.82rem;
    color: var(--c-accent);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .dash-link:hover {
    text-decoration: underline;
  }

  /* ── Modules ── */

  .dash-modules {
    margin-bottom: var(--space-2xl);
  }

  .dash-modules h2 {
    margin-bottom: var(--space-lg);
  }

  .modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-md);
  }

  .module-card {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    text-decoration: none;
    color: var(--c-text);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  a.module-card:hover {
    border-color: var(--c-accent);
    box-shadow: 0 0 0 1px var(--c-accent);
  }

  .module-disabled {
    opacity: 0.55;
    cursor: default;
  }

  .module-icon {
    font-size: 1.4rem;
    flex-shrink: 0;
  }

  .module-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .module-title {
    font-size: 0.9rem;
    font-weight: 600;
  }

  .module-desc {
    font-size: 0.78rem;
    color: var(--c-text-3);
  }

  .module-arrow {
    color: var(--c-accent);
    font-size: 1rem;
  }

  /* ── Badge "bientôt" ── */

  .coming-soon-badge {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--c-text-3);
    background: var(--c-border);
    padding: 2px 7px;
    border-radius: 99px;
  }

  /* ── Liens rapides ── */

  .dash-links {
    display: flex;
    gap: var(--space-xl);
    flex-wrap: wrap;
    padding-top: var(--space-lg);
    border-top: 1px solid var(--c-border);
  }

  .dash-secondary-link {
    font-size: 0.82rem;
    color: var(--c-text-2);
    text-decoration: none;
  }

  .dash-secondary-link:hover {
    color: var(--c-accent);
  }

  @media (max-width: 768px) {
    .overview-stats {
      flex-direction: column;
    }

    .modules-grid {
      grid-template-columns: 1fr;
    }

    .dash-links {
      flex-direction: column;
      gap: var(--space-md);
    }
  }
</style>
