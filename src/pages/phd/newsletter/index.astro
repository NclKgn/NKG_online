---
// src/pages/phd/newsletter/index.astro
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { t, getLocale, base } from '../../../i18n';
import { isSectionVisible } from '../../../lib/visibility';

const ui = t(getLocale());

if (!(await isSectionVisible('phd'))) {
  return Astro.redirect('/');
}

const isDev = import.meta.env.DEV;

// In dev: show all posts (drafts visible with badge + filter)
// In prod: published only
const allPosts = (await getCollection('newsletter'))
  .filter((e) => isDev || !e.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const posts = allPosts;
const hasDrafts = isDev && allPosts.some((p) => p.data.draft);
---

<BaseLayout title="PhD Newsletter" description="Weekly research digests">
  <div class="container section">
    <div class="nl-header">
      <div>
        <h1>Newsletter</h1>
        <p class="newsletter-subtitle">Weekly digests of PhD research progress.</p>
      </div>
      {hasDrafts && (
        <div class="nl-filter" role="group" aria-label="Filtre newsletter">
          <button class="nl-filter-btn active" data-filter="all">Tous</button>
          <button class="nl-filter-btn" data-filter="published">Publiés</button>
        </div>
      )}
    </div>

    <div class="newsletter-list" id="nl-list">
      {posts.map((post) => {
        const formattedDate = post.data.date.toLocaleDateString('en-GB', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });
        return (
          <a
            href={base(`/phd/newsletter/${post.id}`)}
            class="newsletter-item"
            data-draft={post.data.draft ? 'true' : 'false'}
          >
            <time class="mono">{formattedDate}</time>
            <div class="newsletter-item-body">
              <h3>
                {post.data.title}
                {post.data.draft && <span class="draft-badge mono">Brouillon</span>}
              </h3>
              <p>{post.data.summary}</p>
            </div>
          </a>
        );
      })}
    </div>

    <div class="newsletter-rss">
      <a href={base('/rss.xml')} class="mono">{ui.common.rssFeed} &rarr;</a>
    </div>
  </div>
</BaseLayout>

{hasDrafts && (
  <script>
    const btns = document.querySelectorAll<HTMLButtonElement>('.nl-filter-btn');
    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter ?? 'all';
        btns.forEach((b) => b.classList.toggle('active', b === btn));
        document.querySelectorAll<HTMLElement>('#nl-list .newsletter-item').forEach((item) => {
          const isDraft = item.dataset.draft === 'true';
          item.hidden = filter === 'published' && isDraft;
        });
      });
    });
  </script>
)}

<style>
  .newsletter-subtitle {
    font-size: 0.95rem;
    color: var(--c-text-2);
    margin-top: var(--space-sm);
    margin-bottom: var(--space-xl);
  }

  .newsletter-list {
    display: flex;
    flex-direction: column;
  }

  .newsletter-item {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: var(--space-lg);
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--c-border-light);
    text-decoration: none;
    color: var(--c-text);
    transition: background 0.15s;
  }

  .newsletter-item:hover {
    background: var(--c-border-light);
    margin: 0 calc(-1 * var(--space-md));
    padding-left: var(--space-md);
    padding-right: var(--space-md);
    border-radius: var(--radius-sm);
  }

  .newsletter-item time {
    font-size: 0.78rem;
    color: var(--c-text-3);
    padding-top: 3px;
  }

  .newsletter-item h3 {
    font-size: 1.05rem;
    margin-bottom: 4px;
  }

  .newsletter-item p {
    font-size: 0.85rem;
    color: var(--c-text-2);
    line-height: 1.5;
  }

  .newsletter-rss {
    margin-top: var(--space-xl);
    font-size: 0.82rem;
  }

  /* ── Header + filtre (dev only) ── */

  .nl-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .nl-filter {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
    margin-top: var(--space-xs, 4px);
  }

  .nl-filter-btn {
    font-size: 0.72rem;
    font-family: inherit;
    padding: 3px 10px;
    border: 1px solid var(--c-border);
    border-radius: 99px;
    background: transparent;
    color: var(--c-text-2);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }

  .nl-filter-btn:hover {
    border-color: var(--c-accent);
    color: var(--c-accent);
  }

  .nl-filter-btn.active {
    background: var(--c-accent);
    border-color: var(--c-accent);
    color: #fff;
  }

  /* ── Badge brouillon ── */

  .draft-badge {
    font-size: 0.6rem;
    padding: 1px 6px;
    background: color-mix(in srgb, #c09050 15%, transparent);
    color: #c09050;
    border-radius: 99px;
    margin-left: 6px;
    vertical-align: middle;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ── Items cachés par le filtre ── */

  .newsletter-item[hidden] {
    display: none;
  }

  @media (max-width: 768px) {
    .newsletter-item {
      grid-template-columns: 1fr;
      gap: var(--space-xs);
    }
  }
</style>
