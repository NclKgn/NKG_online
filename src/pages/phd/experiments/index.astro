---
// src/pages/phd/experiments/index.astro
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GuestGate from '../../../components/GuestGate.astro';
import ExperimentCard from '../../../components/ExperimentCard.astro';
import { getCollection } from 'astro:content';
import { base } from '../../../i18n';
import { shouldBuild, isGuestOnly, shouldNoIndex } from '../../../lib/visibility';

const pageKey = 'phd/experiments';

if (!(await shouldBuild(pageKey))) {
  return Astro.redirect('/');
}

const needsGate = await isGuestOnly(pageKey);
const noindex = await shouldNoIndex(pageKey);

const isDev = import.meta.env.DEV;
const experiments = (await getCollection('experiments'))
  .filter((e) => isDev || !e.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Tous les tags uniques, triés
const allTags = [...new Set(experiments.flatMap((e) => e.data.tags))].sort();
---

<BaseLayout title="Expériences" noindex={noindex}>
  <GuestGate enabled={needsGate}>
    <div class="container section">

      <a href={base('/phd')} class="back-link mono">&larr; PhD</a>
      <h1>Expériences</h1>
      <p class="exp-subtitle">{experiments.length} expérience{experiments.length > 1 ? 's' : ''} · fiches structurées</p>

      <!-- Filtres -->
      <div class="exp-filters" role="group" aria-label="Filtrer les expériences">
        <div class="filter-group">
          <span class="filter-label small-caps">Statut</span>
          <div class="filter-buttons" id="status-filters">
            <button class="filter-btn active" data-filter-status="all">Tous</button>
            <button class="filter-btn" data-filter-status="planned">Planifiées</button>
            <button class="filter-btn" data-filter-status="ongoing">En cours</button>
            <button class="filter-btn" data-filter-status="completed">Terminées</button>
          </div>
        </div>

        {allTags.length > 0 && (
          <div class="filter-group">
            <span class="filter-label small-caps">Tags</span>
            <div class="filter-buttons" id="tag-filters">
              <button class="filter-btn active" data-filter-tag="all">Tous</button>
              {allTags.map((tag) => (
                <button class="filter-btn" data-filter-tag={tag}>#{tag}</button>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Grille -->
      <div class="exp-grid" id="exp-grid">
        {experiments.map((exp) => (
          <ExperimentCard
            id={exp.id}
            title={exp.data.title}
            date={exp.data.date}
            status={exp.data.status}
            tags={exp.data.tags}
            objective={exp.data.objective}
            hypothesis_main={exp.data.hypothesis_main}
            href={base(`/phd/experiments/${exp.id}`)}
          />
        ))}
      </div>

      <p class="exp-empty" id="exp-empty" hidden>Aucune expérience pour ces filtres.</p>

    </div>
  </GuestGate>
</BaseLayout>

<script>
  // Filtres client-side
  let activeStatus = 'all';
  let activeTag    = 'all';

  function applyFilters() {
    const cards = document.querySelectorAll<HTMLElement>('#exp-grid .ec-card');
    let visible = 0;

    cards.forEach((card) => {
      const status = card.dataset.status ?? '';
      const tags   = (card.dataset.tags ?? '').split(',').filter(Boolean);

      const matchStatus = activeStatus === 'all' || status === activeStatus;
      const matchTag    = activeTag    === 'all' || tags.includes(activeTag);

      if (matchStatus && matchTag) {
        card.removeAttribute('hidden');
        visible++;
      } else {
        card.setAttribute('hidden', '');
      }
    });

    const empty = document.getElementById('exp-empty');
    if (empty) empty.hidden = visible > 0;
  }

  // Boutons statut
  document.getElementById('status-filters')?.addEventListener('click', (evt) => {
    const btn = (evt.target as HTMLElement).closest<HTMLButtonElement>('[data-filter-status]');
    if (!btn) return;
    activeStatus = btn.dataset.filterStatus ?? 'all';
    document.querySelectorAll('#status-filters .filter-btn').forEach((b) =>
      b.classList.toggle('active', b === btn)
    );
    applyFilters();
  });

  // Boutons tag
  document.getElementById('tag-filters')?.addEventListener('click', (evt) => {
    const btn = (evt.target as HTMLElement).closest<HTMLButtonElement>('[data-filter-tag]');
    if (!btn) return;
    activeTag = btn.dataset.filterTag ?? 'all';
    document.querySelectorAll('#tag-filters .filter-btn').forEach((b) =>
      b.classList.toggle('active', b === btn)
    );
    applyFilters();
  });
</script>

<style>
  .back-link {
    font-size: 0.8rem;
    color: var(--c-text-3);
    display: inline-block;
    margin-bottom: var(--space-lg);
    text-decoration: none;
  }
  .back-link:hover { color: var(--c-accent); }

  h1 { margin-bottom: var(--space-xs, 4px); }

  .exp-subtitle {
    font-size: 0.85rem;
    color: var(--c-text-3);
    font-style: italic;
    margin-bottom: var(--space-xl);
  }

  /* ── Filtres ── */

  .exp-filters {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
  }

  .filter-group {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .filter-label {
    font-size: 0.68rem;
    color: var(--c-text-3);
    min-width: 42px;
  }

  .filter-buttons {
    display: flex;
    gap: var(--space-xs, 4px);
    flex-wrap: wrap;
  }

  .filter-btn {
    font-size: 0.72rem;
    font-family: inherit;
    padding: 3px 10px;
    border: 1px solid var(--c-border);
    border-radius: 99px;
    background: transparent;
    color: var(--c-text-2);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }

  .filter-btn:hover {
    border-color: var(--c-accent);
    color: var(--c-accent);
  }

  .filter-btn.active {
    background: var(--c-accent);
    border-color: var(--c-accent);
    color: #fff;
  }

  /* ── Grille ── */

  .exp-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-md);
  }

  /* ── Message vide ── */

  .exp-empty {
    font-size: 0.85rem;
    color: var(--c-text-3);
    font-style: italic;
    padding: var(--space-xl) 0;
    text-align: center;
  }

  @media (max-width: 768px) {
    .exp-grid {
      grid-template-columns: 1fr;
    }

    .filter-group {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--space-sm);
    }
  }
</style>
