---
// src/components/PipelineTracker.astro
// EPIC 18 — Tracker de pipelines d'analyse (données depuis PhD_Notebook via bridge)
import { getEntry } from 'astro:content';
import { t, getLocale } from '../i18n';

const ui = t(getLocale()).dashboard.pipelines;

const entry = await getEntry('pipelines-data', 'pipelines-data');
const data  = entry?.data;
const pipelines = data?.pipelines ?? [];
const hasData   = pipelines.length > 0;

// ── Stats ──────────────────────────────────────────────────────────────────

const total      = pipelines.length;
const inProgress = pipelines.filter((p) => p.status === 'IN_PROGRESS').length;
const completed  = pipelines.filter((p) => p.status === 'COMPLETED').length;

// Par axe
const AXIS_ORDER  = ['biologie', 'biomecanique', 'donnees-humaines'] as const;
const AXIS_COLOR: Record<string, string> = {
  biologie:          '#6080a0',
  biomecanique:      '#e07b2a',
  'donnees-humaines':'#c0392b',
};

const byAxis: Record<string, number> = {};
for (const p of pipelines) {
  byAxis[p.axis] = (byAxis[p.axis] ?? 0) + 1;
}

// ── Config badges ──────────────────────────────────────────────────────────

const STATUS_CLS: Record<string, string> = {
  PLANNED:    'pt-status-planned',
  IN_PROGRESS:'pt-status-inprogress',
  COMPLETED:  'pt-status-completed',
  ARCHIVED:   'pt-status-archived',
};

const STEP_STATUS_CLS: Record<string, string> = {
  PLANNED:    'pt-step-planned',
  IN_PROGRESS:'pt-step-inprogress',
  COMPLETED:  'pt-step-completed',
};

const STEP_TYPE_ICON: Record<string, string> = {
  acquisition:   '📷',
  preprocessing: '⚙',
  analysis:      '📊',
  figure:        '🖼',
};

// Sync info
const syncRaw   = data?.generated_at;
const syncLabel = syncRaw
  ? new Date(syncRaw).toLocaleDateString('fr-FR', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })
  : ui.never;
---

<div class="pt-root">

  <!-- Stats -->
  <div class="pt-stats">
    <div class="pt-stat">
      <span class="pt-stat-val">{total}</span>
      <span class="pt-stat-lbl">{ui.total}</span>
    </div>
    <div class="pt-stat">
      <span class="pt-stat-val pt-color-inprogress">{inProgress}</span>
      <span class="pt-stat-lbl">{ui.inProgress}</span>
    </div>
    <div class="pt-stat">
      <span class="pt-stat-val pt-color-completed">{completed}</span>
      <span class="pt-stat-lbl">{ui.completed}</span>
    </div>
    {AXIS_ORDER.filter((a) => byAxis[a]).map((axis) => (
      <div class="pt-stat">
        <span class="pt-stat-val" style={`color: ${AXIS_COLOR[axis]}`}>{byAxis[axis]}</span>
        <span class="pt-stat-lbl">{ui.axisLbls[axis as keyof typeof ui.axisLbls]}</span>
      </div>
    ))}
    <div class="pt-stat pt-stat-sync">
      <span class="pt-sync-label">{ui.syncInfo}</span>
      <span class="pt-sync-val mono">{syncLabel}</span>
    </div>
  </div>

  <!-- Liste des pipelines -->
  {hasData ? (
    <div class="pt-list">
      {pipelines.map((pipeline) => {
        const axisColor = AXIS_COLOR[pipeline.axis] ?? 'var(--c-text-3)';
        const stepsDone  = pipeline.steps.filter((s) => s.status === 'COMPLETED').length;
        const stepsTotal = pipeline.steps.length;
        const progressPct = stepsTotal > 0 ? Math.round((stepsDone / stepsTotal) * 100) : 0;

        return (
          <div class={`pt-card ${pipeline.status === 'ARCHIVED' ? 'pt-card-archived' : ''}`}>

            <!-- En-tête pipeline -->
            <div class="pt-card-header">
              <div class="pt-card-meta">
                <span class="pt-axis-dot" style={`background: ${axisColor}`}></span>
                <span class="pt-axis-label" style={`color: ${axisColor}`}>
                  {ui.axisLbls[pipeline.axis as keyof typeof ui.axisLbls]}
                </span>
                <span class={`pt-badge ${STATUS_CLS[pipeline.status]}`}>
                  {ui.statusLbls[pipeline.status as keyof typeof ui.statusLbls]}
                </span>
              </div>
              <h3 class="pt-name">{pipeline.name}</h3>
            </div>

            <!-- Barre de progression -->
            <div class="pt-progress-wrap">
              <div class="pt-progress-bar">
                <div class="pt-progress-fill" style={`width: ${progressPct}%; background: ${axisColor}`}></div>
              </div>
              <span class="pt-progress-label mono">{stepsDone}/{stepsTotal}</span>
            </div>

            <!-- Steps (chips) -->
            <div class="pt-steps">
              {pipeline.steps.map((step) => (
                <div class={`pt-step ${STEP_STATUS_CLS[step.status]}`}>
                  <span class="pt-step-icon">{STEP_TYPE_ICON[step.type] ?? '▸'}</span>
                  <span class="pt-step-label">{step.label}</span>
                  <span class="pt-step-type mono">
                    {ui.stepTypeLbls[step.type as keyof typeof ui.stepTypeLbls]}
                  </span>
                </div>
              ))}
            </div>

            <!-- Meta bas -->
            {(pipeline.experiments?.length || pipeline.figures?.length || pipeline.notes) && (
              <div class="pt-card-footer">
                {pipeline.experiments && pipeline.experiments.length > 0 && (
                  <span class="pt-meta-item mono">
                    ⚗ {pipeline.experiments.join(', ')}
                  </span>
                )}
                {pipeline.figures && pipeline.figures.length > 0 && (
                  <span class="pt-meta-item mono">
                    Fig. {pipeline.figures.join(', ')}
                  </span>
                )}
                {pipeline.notes && (
                  <span class="pt-notes">{pipeline.notes}</span>
                )}
              </div>
            )}

          </div>
        );
      })}
    </div>
  ) : (
    <div class="pt-empty">
      <p class="pt-empty-msg">{ui.empty}</p>
      <p class="pt-empty-hint">{ui.runBridge}</p>
      <pre class="pt-empty-cmd">python scripts/notebook-export.py --only pipelines</pre>
    </div>
  )}

</div>

<style>
  /* ── Stats ── */

  .pt-stats {
    display: flex;
    gap: var(--space-xl);
    flex-wrap: wrap;
    align-items: flex-end;
    margin-bottom: var(--space-xl);
    padding: var(--space-lg);
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: 8px;
  }

  .pt-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .pt-stat-sync {
    margin-left: auto;
    align-items: flex-end;
  }

  .pt-stat-val {
    font-size: 1.8rem;
    font-weight: 700;
    font-family: var(--font-mono, monospace);
    line-height: 1;
    color: var(--c-text);
  }

  .pt-stat-lbl {
    font-size: 0.7rem;
    color: var(--c-text-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .pt-sync-label {
    font-size: 0.68rem;
    color: var(--c-text-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pt-sync-val {
    font-size: 0.72rem;
    color: var(--c-text-2);
  }

  .pt-color-inprogress { color: #6080a0; }
  .pt-color-completed  { color: var(--c-success); }

  /* ── Liste pipelines ── */

  .pt-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .pt-card {
    border: 1px solid var(--c-border);
    border-radius: 8px;
    padding: var(--space-lg);
    background: var(--c-surface);
  }

  .pt-card-archived {
    opacity: 0.5;
  }

  .pt-card-header {
    margin-bottom: var(--space-md);
  }

  .pt-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs, 4px);
  }

  .pt-axis-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .pt-axis-label {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .pt-name {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0;
    color: var(--c-text);
  }

  /* ── Barre de progression ── */

  .pt-progress-wrap {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .pt-progress-bar {
    flex: 1;
    height: 4px;
    background: var(--c-border);
    border-radius: 99px;
    overflow: hidden;
  }

  .pt-progress-fill {
    height: 100%;
    border-radius: 99px;
    transition: width 0.3s ease;
  }

  .pt-progress-label {
    font-size: 0.68rem;
    color: var(--c-text-3);
    flex-shrink: 0;
  }

  /* ── Steps (chips) ── */

  .pt-steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs, 4px);
    margin-bottom: var(--space-md);
  }

  .pt-step {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 5px var(--space-sm);
    border-radius: 6px;
    font-size: 0.82rem;
  }

  .pt-step-icon {
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  .pt-step-label {
    flex: 1;
    color: var(--c-text);
  }

  .pt-step-type {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--c-text-3);
    flex-shrink: 0;
  }

  /* Step status colors */
  .pt-step-planned {
    background: color-mix(in srgb, var(--c-border) 40%, transparent);
    opacity: 0.7;
  }

  .pt-step-inprogress {
    background: color-mix(in srgb, #6080a0 10%, transparent);
    border-left: 2px solid #6080a0;
  }

  .pt-step-inprogress .pt-step-label {
    color: var(--c-text);
  }

  .pt-step-completed {
    background: color-mix(in srgb, var(--c-success) 10%, transparent);
  }

  .pt-step-completed .pt-step-label {
    color: var(--c-text-2);
    text-decoration: line-through;
    text-decoration-color: var(--c-success);
  }

  /* ── Footer carte ── */

  .pt-card-footer {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    padding-top: var(--space-sm);
    border-top: 1px solid var(--c-border);
    align-items: flex-start;
  }

  .pt-meta-item {
    font-size: 0.68rem;
    color: var(--c-text-3);
    background: var(--c-border);
    padding: 2px 8px;
    border-radius: 99px;
  }

  .pt-notes {
    font-size: 0.78rem;
    color: var(--c-text-2);
    font-style: italic;
    width: 100%;
    margin-top: 2px;
  }

  /* ── Badges statut pipeline ── */

  .pt-badge {
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px 7px;
    border-radius: 99px;
  }

  .pt-status-planned {
    background: var(--c-border);
    color: var(--c-text-3);
  }

  .pt-status-inprogress {
    background: color-mix(in srgb, #6080a0 12%, transparent);
    color: #6080a0;
  }

  .pt-status-completed {
    background: color-mix(in srgb, var(--c-success) 12%, transparent);
    color: var(--c-success);
  }

  .pt-status-archived {
    background: var(--c-border);
    color: var(--c-text-3);
  }

  /* ── Empty state ── */

  .pt-empty {
    padding: var(--space-xl) 0;
    text-align: center;
  }

  .pt-empty-msg {
    font-size: 0.9rem;
    color: var(--c-text-2);
    font-style: italic;
    margin-bottom: var(--space-sm);
  }

  .pt-empty-hint {
    font-size: 0.8rem;
    color: var(--c-text-3);
    margin-bottom: var(--space-sm);
  }

  .pt-empty-cmd {
    display: inline-block;
    font-size: 0.78rem;
    font-family: var(--font-mono, monospace);
    background: var(--c-border);
    color: var(--c-text-2);
    padding: var(--space-xs, 4px) var(--space-md);
    border-radius: 6px;
  }

  /* ── Responsive ── */

  @media (max-width: 768px) {
    .pt-stats {
      gap: var(--space-lg);
    }

    .pt-stat-sync {
      margin-left: 0;
      align-items: flex-start;
    }

    .pt-steps {
      gap: var(--space-xs, 6px);
    }
  }
</style>
