---
// src/components/PubMedRadar.astro
// EPIC 20 — Radar littérature PubMed
// Articles récupérés via scripts/pubmed-radar.py ou manuellement
// Source des données : PubMed (https://pubmed.ncbi.nlm.nih.gov)
import { getEntry } from 'astro:content';
import { t, getLocale } from '../i18n';

const ui = t(getLocale()).dashboard.pubmed;

const entry = await getEntry('pubmed-alerts', 'pubmed-alerts');
const data  = entry?.data;
const articles = data?.articles ?? [];
const queries  = data?.queries  ?? [];
const hasData  = articles.length > 0;

// ── Stats ──────────────────────────────────────────────────────────────────

const total  = articles.length;
const unread = articles.filter((a) => !a.read).length;

const fetchedRaw   = data?.fetched_at;
const fetchedLabel = fetchedRaw
  ? new Date(fetchedRaw).toLocaleDateString('fr-FR', { year: 'numeric', month: 'short', day: 'numeric' })
  : ui.never;

// Map query_id → label
const queryMap = new Map(queries.map((q) => [q.id, q.label]));

// Grouper par query_id pour l'affichage
const byQuery = new Map<string, typeof articles>();
for (const a of articles) {
  if (!byQuery.has(a.query_id)) byQuery.set(a.query_id, []);
  byQuery.get(a.query_id)!.push(a);
}
---

<div class="pm-root">

  <!-- Stats -->
  <div class="pm-stats">
    <div class="pm-stat">
      <span class="pm-stat-val">{total}</span>
      <span class="pm-stat-lbl">{ui.total}</span>
    </div>
    <div class="pm-stat">
      <span class="pm-stat-val pm-color-unread">{unread}</span>
      <span class="pm-stat-lbl">{ui.unread}</span>
    </div>
    {queries.map((q) => {
      const count = byQuery.get(q.id)?.length ?? 0;
      return count > 0 ? (
        <div class="pm-stat">
          <span class="pm-stat-val pm-color-dim">{count}</span>
          <span class="pm-stat-lbl">{q.label}</span>
        </div>
      ) : null;
    })}
    <div class="pm-stat pm-stat-sync">
      <span class="pm-sync-label">{ui.fetchedAt}</span>
      <span class="pm-sync-val mono">{fetchedLabel}</span>
    </div>
  </div>

  <!-- Articles groupés par requête -->
  {hasData ? (
    <div class="pm-groups">
      {[...byQuery.entries()].map(([qid, items]) => (
        <div class="pm-group">
          <div class="pm-group-header">
            <span class="pm-group-label">{queryMap.get(qid) ?? qid}</span>
            <span class="pm-group-count">{items.length}</span>
          </div>
          <div class="pm-articles">
            {items.map((article) => (
              <div
                class={`pm-article ${article.read ? 'pm-article-read' : ''}`}
                data-pmid={article.pmid}
              >
                <div class="pm-article-body">
                  <p class="pm-title">{article.title}</p>
                  <div class="pm-meta">
                    <span class="pm-authors mono">{article.authors}</span>
                    <span class="pm-sep">·</span>
                    <span class="pm-journal">{article.journal}</span>
                    <span class="pm-sep">·</span>
                    <span class="pm-date mono">{article.date.slice(0, 7)}</span>
                  </div>
                </div>
                <div class="pm-article-actions">
                  <a
                    href={`https://doi.org/${article.doi}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="pm-link mono"
                  >
                    {ui.openPubmed}
                  </a>
                  <button
                    class="pm-read-btn"
                    data-pmid={article.pmid}
                    data-read={article.read ? 'true' : 'false'}
                    title={article.read ? ui.markUnread : ui.markRead}
                  >
                    {article.read ? '✓' : '○'}
                  </button>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  ) : (
    <div class="pm-empty">
      <p class="pm-empty-msg">{ui.empty}</p>
      <p class="pm-empty-hint">{ui.runScript}</p>
      <pre class="pm-empty-cmd">python scripts/pubmed-radar.py</pre>
    </div>
  )}

  <!-- Attribution PubMed (légalement requise) -->
  <p class="pm-source">{ui.source}</p>

</div>

<script>
  // Gestion de l'état "lu" en sessionStorage (côté client)
  // Clé : pm-read-<pmid> → 'true' | 'false'

  const STORAGE_PREFIX = 'pm-read-';

  function getReadState(pmid: string): boolean {
    return sessionStorage.getItem(STORAGE_PREFIX + pmid) === 'true';
  }

  function setReadState(pmid: string, read: boolean): void {
    sessionStorage.setItem(STORAGE_PREFIX + pmid, read ? 'true' : 'false');
  }

  function applyReadState(card: HTMLElement, read: boolean): void {
    const btn = card.querySelector<HTMLButtonElement>('.pm-read-btn');
    if (!btn) return;
    if (read) {
      card.classList.add('pm-article-read');
      btn.textContent = '✓';
      btn.dataset.read = 'true';
    } else {
      card.classList.remove('pm-article-read');
      btn.textContent = '○';
      btn.dataset.read = 'false';
    }
  }

  // Initialiser depuis sessionStorage au chargement
  document.querySelectorAll<HTMLElement>('.pm-article').forEach((card) => {
    const pmid = card.dataset.pmid;
    if (!pmid) return;
    const stored = sessionStorage.getItem(STORAGE_PREFIX + pmid);
    if (stored !== null) {
      applyReadState(card, stored === 'true');
    }
  });

  // Toggle au clic
  document.querySelectorAll<HTMLButtonElement>('.pm-read-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const pmid = btn.dataset.pmid;
      if (!pmid) return;
      const currentRead = btn.dataset.read === 'true';
      const newRead = !currentRead;
      setReadState(pmid, newRead);
      const card = btn.closest<HTMLElement>('.pm-article');
      if (card) applyReadState(card, newRead);
    });
  });
</script>

<style>
  /* ── Stats ── */

  .pm-stats {
    display: flex;
    gap: var(--space-xl);
    flex-wrap: wrap;
    align-items: flex-end;
    margin-bottom: var(--space-xl);
    padding: var(--space-lg);
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: 8px;
  }

  .pm-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .pm-stat-sync {
    margin-left: auto;
    align-items: flex-end;
  }

  .pm-stat-val {
    font-size: 1.8rem;
    font-weight: 700;
    font-family: var(--font-mono, monospace);
    line-height: 1;
    color: var(--c-text);
  }

  .pm-stat-lbl {
    font-size: 0.7rem;
    color: var(--c-text-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .pm-sync-label {
    font-size: 0.68rem;
    color: var(--c-text-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pm-sync-val {
    font-size: 0.72rem;
    color: var(--c-text-2);
  }

  .pm-color-unread { color: var(--c-accent); }
  .pm-color-dim    { color: var(--c-text-2); }

  /* ── Groupes ── */

  .pm-groups {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .pm-group-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-xs, 6px);
    border-bottom: 1px solid var(--c-border);
  }

  .pm-group-label {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--c-text-2);
  }

  .pm-group-count {
    font-size: 0.68rem;
    font-family: var(--font-mono, monospace);
    color: var(--c-text-3);
    background: var(--c-border);
    padding: 1px 6px;
    border-radius: 99px;
  }

  /* ── Articles ── */

  .pm-articles {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .pm-article {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    padding: var(--space-md);
    border: 1px solid var(--c-border);
    border-radius: 6px;
    background: var(--c-surface);
    transition: border-color 0.15s;
  }

  .pm-article:hover {
    border-color: var(--c-accent);
  }

  .pm-article-read {
    opacity: 0.55;
  }

  .pm-article-body {
    flex: 1;
    min-width: 0;
  }

  .pm-title {
    font-size: 0.87rem;
    font-weight: 600;
    color: var(--c-text);
    margin-bottom: var(--space-xs, 4px);
    line-height: 1.4;
  }

  .pm-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    align-items: center;
    font-size: 0.72rem;
    color: var(--c-text-3);
  }

  .pm-authors { color: var(--c-text-2); }
  .pm-journal { font-style: italic; }
  .pm-sep     { color: var(--c-border); }

  /* ── Actions ── */

  .pm-article-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-xs, 6px);
    flex-shrink: 0;
  }

  .pm-link {
    font-size: 0.68rem;
    color: var(--c-accent);
    text-decoration: none;
    white-space: nowrap;
  }

  .pm-link:hover {
    text-decoration: underline;
  }

  .pm-read-btn {
    background: none;
    border: 1px solid var(--c-border);
    border-radius: 50%;
    width: 22px;
    height: 22px;
    font-size: 0.72rem;
    cursor: pointer;
    color: var(--c-text-3);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.15s, color 0.15s;
  }

  .pm-read-btn:hover {
    border-color: var(--c-accent);
    color: var(--c-accent);
  }

  /* ── Empty state ── */

  .pm-empty {
    padding: var(--space-xl) 0;
    text-align: center;
  }

  .pm-empty-msg {
    font-size: 0.9rem;
    color: var(--c-text-2);
    font-style: italic;
    margin-bottom: var(--space-sm);
  }

  .pm-empty-hint {
    font-size: 0.8rem;
    color: var(--c-text-3);
    margin-bottom: var(--space-sm);
  }

  .pm-empty-cmd {
    display: inline-block;
    font-size: 0.78rem;
    font-family: var(--font-mono, monospace);
    background: var(--c-border);
    color: var(--c-text-2);
    padding: var(--space-xs, 4px) var(--space-md);
    border-radius: 6px;
  }

  /* ── Attribution ── */

  .pm-source {
    margin-top: var(--space-lg);
    font-size: 0.65rem;
    color: var(--c-text-3);
    text-align: right;
    font-style: italic;
  }

  /* ── Responsive ── */

  @media (max-width: 768px) {
    .pm-stats {
      gap: var(--space-lg);
    }

    .pm-stat-sync {
      margin-left: 0;
      align-items: flex-start;
    }

    .pm-article {
      flex-direction: column;
    }

    .pm-article-actions {
      flex-direction: row;
      align-items: center;
    }
  }
</style>
