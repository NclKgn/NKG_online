---
// src/components/FigureTracker.astro
// EPIC 19 — Tracker de figures
import { getEntry, getCollection } from 'astro:content';
import { t, getLocale } from '../i18n';

const ui = t(getLocale()).dashboard.figures;

// Load figures
const figuresEntry = await getEntry('figures', 'figures-data');
const figures = figuresEntry?.data.figures ?? [];

// Load experiments for outdated detection (EPIC 19.3)
const experiments = await getCollection('experiments');
const expBySlug = new Map(experiments.map((e) => [e.id, e.data.date]));

// Targets in display order
const TARGETS = ['article-1', 'article-2', 'article-scoping', 'thesis'] as const;

// Determine if a figure is outdated:
// source_experiment is set AND that experiment's date > figure.last_updated
function isOutdated(fig: (typeof figures)[number]): boolean {
  if (!fig.source_experiment) return false;
  const expDate = expBySlug.get(fig.source_experiment);
  if (!expDate) return false;
  return expDate.getTime() > fig.last_updated.getTime();
}

// Annotate figures with outdated flag
const annotated = figures.map((fig) => ({ ...fig, outdated: isOutdated(fig) }));

// Global stats
const total      = annotated.length;
const finalisees = annotated.filter((f) => f.status === 'finalisee').length;
const brouillons = annotated.filter((f) => f.status === 'brouillon').length;
const aRefaire   = annotated.filter((f) => f.status === 'a-refaire').length;
const outdatedCount = annotated.filter((f) => f.outdated).length;

// Group by target
const byTarget = new Map<string, typeof annotated>(
  TARGETS.map((t) => [t, annotated.filter((f) => f.target === t)])
);

// Status config
const STATUS_CONFIG = {
  finalisee:  { cls: 'ft-finalisee' },
  brouillon:  { cls: 'ft-brouillon' },
  'a-refaire':{ cls: 'ft-arefaire'  },
} as const;

function fmtDate(d: Date) {
  return d.toLocaleDateString('fr-FR', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<div class="ft-root">

  <!-- Stats globales -->
  <div class="ft-stats">
    <div class="ft-stat">
      <span class="ft-stat-value">{total}</span>
      <span class="ft-stat-label">{ui.total}</span>
    </div>
    <div class="ft-stat">
      <span class="ft-stat-value ft-color-fin">{finalisees}</span>
      <span class="ft-stat-label">{ui.finalisee}</span>
    </div>
    <div class="ft-stat">
      <span class="ft-stat-value ft-color-brou">{brouillons}</span>
      <span class="ft-stat-label">{ui.brouillon}</span>
    </div>
    <div class="ft-stat">
      <span class="ft-stat-value ft-color-ref">{aRefaire}</span>
      <span class="ft-stat-label">{ui.aRefaire}</span>
    </div>
    {outdatedCount > 0 && (
      <div class="ft-stat">
        <span class="ft-stat-value ft-color-out">{outdatedCount}</span>
        <span class="ft-stat-label">{ui.outdated}</span>
      </div>
    )}
  </div>

  <!-- Sections par cible -->
  {TARGETS.map((target) => {
    const figs = byTarget.get(target) ?? [];
    if (figs.length === 0) return null;
    return (
      <div class="ft-section">
        <h3 class="ft-section-title">{ui.targets[target]}</h3>
        <div class="ft-grid">
          {figs.map((fig) => {
            const sc = STATUS_CONFIG[fig.status];
            const labelKey = fig.status as keyof typeof ui.statut;
            return (
              <div class={`ft-card card ${fig.outdated ? 'ft-card-outdated' : ''}`}>
                <div class="ft-card-header">
                  <span class={`ft-badge ${sc.cls}`}>{ui.statut[labelKey]}</span>
                  <div class="ft-card-badges">
                    {fig.auto_generated && (
                      <span class="ft-badge-auto">{ui.autoGenerated}</span>
                    )}
                    {fig.outdated && (
                      <span class="ft-badge-outdated">{ui.outdatedLabel}</span>
                    )}
                  </div>
                </div>

                <p class="ft-card-title">{fig.title}</p>

                {fig.chapter && (
                  <p class="ft-card-chapter">{fig.chapter}</p>
                )}

                <div class="ft-card-footer">
                  <span class="ft-card-date mono">{fmtDate(fig.last_updated)}</span>
                  {fig.source_experiment && (
                    <span class="ft-card-exp mono">{ui.sourceExp}: {fig.source_experiment}</span>
                  )}
                </div>

                {fig.notes && (
                  <p class="ft-card-notes">{fig.notes}</p>
                )}
              </div>
            );
          })}
        </div>
      </div>
    );
  })}

</div>

<style>
  /* ── Stats ── */

  .ft-stats {
    display: flex;
    gap: var(--space-xl);
    flex-wrap: wrap;
    margin-bottom: var(--space-2xl);
    padding: var(--space-lg);
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: 8px;
  }

  .ft-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ft-stat-value {
    font-size: 1.8rem;
    font-weight: 700;
    font-family: var(--font-mono, monospace);
    line-height: 1;
    color: var(--c-text);
  }

  .ft-stat-label {
    font-size: 0.7rem;
    color: var(--c-text-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .ft-color-fin  { color: var(--c-success); }
  .ft-color-brou { color: #c09050; }
  .ft-color-ref  { color: #c0392b; }
  .ft-color-out  { color: #b05e3a; }

  /* ── Sections ── */

  .ft-section {
    margin-bottom: var(--space-2xl);
  }

  .ft-section-title {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-text-2);
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-xs, 4px);
    border-bottom: 1px solid var(--c-border);
  }

  .ft-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-md);
  }

  /* ── Cards ── */

  .ft-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs, 6px);
    padding: var(--space-md) var(--space-lg);
  }

  .ft-card-outdated {
    border-color: color-mix(in srgb, #b05e3a 40%, transparent);
  }

  .ft-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xs, 4px);
  }

  .ft-card-badges {
    display: flex;
    gap: 4px;
  }

  /* ── Badges statut ── */

  .ft-badge {
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px 7px;
    border-radius: 99px;
    flex-shrink: 0;
  }

  .ft-finalisee {
    background: color-mix(in srgb, var(--c-success) 15%, transparent);
    color: var(--c-success);
  }

  .ft-brouillon {
    background: color-mix(in srgb, #c09050 15%, transparent);
    color: #c09050;
  }

  .ft-arefaire {
    background: color-mix(in srgb, #c0392b 15%, transparent);
    color: #c0392b;
  }

  .ft-badge-auto {
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px 6px;
    border-radius: 99px;
    background: color-mix(in srgb, #6080a0 15%, transparent);
    color: #6080a0;
  }

  .ft-badge-outdated {
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px 6px;
    border-radius: 99px;
    background: color-mix(in srgb, #b05e3a 15%, transparent);
    color: #b05e3a;
  }

  /* ── Card content ── */

  .ft-card-title {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--c-text);
    line-height: 1.4;
    margin: 0;
  }

  .ft-card-chapter {
    font-size: 0.72rem;
    color: var(--c-text-3);
    margin: 0;
    font-style: italic;
  }

  .ft-card-footer {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: var(--space-xs, 4px);
  }

  .ft-card-date {
    font-size: 0.68rem;
    color: var(--c-text-3);
  }

  .ft-card-exp {
    font-size: 0.62rem;
    color: var(--c-text-3);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ft-card-notes {
    font-size: 0.75rem;
    color: var(--c-text-2);
    font-style: italic;
    border-left: 2px solid var(--c-border);
    padding-left: var(--space-sm);
    margin: 0;
    line-height: 1.45;
  }

  /* ── Responsive ── */

  @media (max-width: 768px) {
    .ft-stats {
      gap: var(--space-lg);
    }

    .ft-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
